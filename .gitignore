# Godot import cache + local test artifacts
godot/.godot/
godot/test_out/

# Obsidian volatile UI state (el vault sí se trackea)
Aether Bound/.obsidian/workspace.json

# Sub-vaults accidentales de Obsidian (abrir subcarpetas como vault crea
# .obsidian anidados — UI local, no se versionan; el vault root es Aether Bound/)
Aether Bound/*/.obsidian/
Aether Bound/*/*/.obsidian/

# Beckett MCP: config local auto-escrita por el addon (no versionar)
.mcp.json
godot/.mcp.json

# Privados del Vault (SCHEMA §8 / VAULT-STARTER §5.5) — glob, no línea
# literal: cubre el archivo y cualquier split futuro (ej. -Archivo.md) sin
# volver a tocar este .gitignore. No existen todavía; se crean solo si
# Boris los pide.
Aether Bound/20-State/Notas-Privadas*
Aether Bound/20-State/Bitacora-Privada*
